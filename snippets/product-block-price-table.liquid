{% liquid
  comment
    Renders a product price display.

    Required parameters:
      - prod: { Object } The associated product object
      - current_variant: { Object } The current variant object.
      - block: {Object} Current block
  endcomment
-%}
{%- if prod != blank -%}
  <script>console.log({{ block.settings | json }});</script>
  <div class="products">
    {% if block.settings.price_table_title -%}
    <h3>{{ block.settings.price_table_title}}</h3>
      <br>
 {%- endif %}     
    <table class="account__table smart-table">
      <thead>
        <tr>
          <th>Qty</th>
          <th>Savings</th>
        </tr>
      </thead>
      <tbody>

        {%- assign discounts = block.settings.price_table_discounts | split: ',' -%}
        {%- assign quantities = block.settings.price_table_quantities | split: ',' -%}
        {%- assign i=0 -%}

        {% for discount in discounts -%}
         <tr class="">
          <td style='text-align:center; vertical-align:middle'> {{ quantities[i] }}</td>
          <td style='text-align:center; vertical-align:middle'> {{ discount }}% </td>
           {%- assign i= 1|plus: i -%}
        </tr>
        {%- endfor %}

      </tbody>
    </table>
  </div>
{%- endif %}
