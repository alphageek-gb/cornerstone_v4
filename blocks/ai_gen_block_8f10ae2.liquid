{% doc %}
  @prompt
    i want a listing of all products in one collection
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-collection-listing-{{ ai_gen_id }} {
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    display: block;
  }

  .ai-collection-listing__header-{{ ai_gen_id }} {
    margin-bottom: {{ block.settings.spacing_above_products }}px;
    text-align: {{ block.settings.header_alignment }};
  }

  .ai-collection-listing__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0 0 12px 0;
  }

  .ai-collection-listing__description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_size }}px;
    color: {{ block.settings.description_color }};
    margin: 0;
  }

  .ai-collection-listing__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.grid_gap }}px;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .ai-collection-listing__item-{{ ai_gen_id }} {
    position: relative;
  }

  .ai-collection-listing__link-{{ ai_gen_id }} {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .ai-collection-listing__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: {% if block.settings.image_ratio == 'natural' %}100%{% elsif block.settings.image_ratio == 'square' %}100%{% elsif block.settings.image_ratio == 'portrait' %}125%{% elsif block.settings.image_ratio == 'landscape' %}75%{% endif %};
    overflow: hidden;
    background-color: #f4f4f4;
    border-radius: {{ block.settings.image_border_radius }}px;
    margin-bottom: 12px;
  }

  .ai-collection-listing__image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: {{ block.settings.image_fit }};
  }

  .ai-collection-listing__placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-collection-listing__placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 200px;
    max-height: 200px;
  }

  .ai-collection-listing__product-info-{{ ai_gen_id }} {
    text-align: {{ block.settings.product_info_alignment }};
  }

  .ai-collection-listing__product-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.product_title_size }}px;
    color: {{ block.settings.product_title_color }};
    margin: 0 0 8px 0;
    font-weight: 600;
  }

  .ai-collection-listing__product-vendor-{{ ai_gen_id }} {
    font-size: {{ block.settings.product_vendor_size }}px;
    color: {{ block.settings.product_vendor_color }};
    margin: 0 0 8px 0;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .ai-collection-listing__product-price-{{ ai_gen_id }} {
    font-size: {{ block.settings.product_price_size }}px;
    color: {{ block.settings.product_price_color }};
    font-weight: 600;
  }

  .ai-collection-listing__product-price--sale-{{ ai_gen_id }} {
    color: {{ block.settings.sale_price_color }};
  }

  .ai-collection-listing__product-price--compare-{{ ai_gen_id }} {
    text-decoration: line-through;
    opacity: 0.6;
    margin-left: 8px;
  }

  .ai-collection-listing__empty-state-{{ ai_gen_id }} {
    text-align: center;
    padding: 60px 20px;
    color: #666;
  }

  .ai-collection-listing__empty-state-title-{{ ai_gen_id }} {
    font-size: 20px;
    margin: 0 0 8px 0;
  }

  .ai-collection-listing__empty-state-text-{{ ai_gen_id }} {
    font-size: 14px;
    margin: 0;
  }

  @media screen and (max-width: 749px) {
    .ai-collection-listing__grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
    }

    .ai-collection-listing__title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.title_size }}px * 0.85);
    }

    .ai-collection-listing__description-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.description_size }}px * 0.9);
    }
  }
{% endstyle %}

<collection-listing-{{ ai_gen_id }}
  class="ai-collection-listing-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  {% if block.settings.collection != blank %}
    {% assign collection = block.settings.collection %}
    
    {% if block.settings.show_collection_info %}
      <div class="ai-collection-listing__header-{{ ai_gen_id }}">
        {% if block.settings.show_collection_title and collection.title != blank %}
          <h2 class="ai-collection-listing__title-{{ ai_gen_id }}">{{ collection.title }}</h2>
        {% endif %}
        
        {% if block.settings.show_collection_description and collection.description != blank %}
          <div class="ai-collection-listing__description-{{ ai_gen_id }}">{{ collection.description }}</div>
        {% endif %}
      </div>
    {% endif %}

    {% if collection.products.size > 0 %}
      <ul class="ai-collection-listing__grid-{{ ai_gen_id }}">
        {% for product in collection.products limit: block.settings.products_to_show %}
          <li class="ai-collection-listing__item-{{ ai_gen_id }}">
            <a href="{{ product.url }}" class="ai-collection-listing__link-{{ ai_gen_id }}">
              <div class="ai-collection-listing__image-wrapper-{{ ai_gen_id }}">
                {% if product.featured_image %}
                  <img
                    src="{{ product.featured_image | image_url: width: 800 }}"
                    alt="{{ product.featured_image.alt | escape }}"
                    class="ai-collection-listing__image-{{ ai_gen_id }}"
                    loading="lazy"
                    width="{{ product.featured_image.width }}"
                    height="{{ product.featured_image.height }}"
                  >
                {% else %}
                  <div class="ai-collection-listing__placeholder-{{ ai_gen_id }}">
                    {{ 'product-1' | placeholder_svg_tag }}
                  </div>
                {% endif %}
              </div>

              <div class="ai-collection-listing__product-info-{{ ai_gen_id }}">
                {% if block.settings.show_vendor and product.vendor != blank %}
                  <div class="ai-collection-listing__product-vendor-{{ ai_gen_id }}">{{ product.vendor }}</div>
                {% endif %}

                <h3 class="ai-collection-listing__product-title-{{ ai_gen_id }}">{{ product.title }}</h3>

                {% if block.settings.show_price %}
                  <div class="ai-collection-listing__product-price-{{ ai_gen_id }}">
                    {% if product.compare_at_price > product.price %}
                      <span class="ai-collection-listing__product-price--sale-{{ ai_gen_id }}">
                        {{ product.price | money }}
                      </span>
                      <span class="ai-collection-listing__product-price--compare-{{ ai_gen_id }}">
                        {{ product.compare_at_price | money }}
                      </span>
                    {% else %}
                      {{ product.price | money }}
                    {% endif %}
                  </div>
                {% endif %}
              </div>
            </a>
          </li>
        {% endfor %}
      </ul>
    {% else %}
      <div class="ai-collection-listing__empty-state-{{ ai_gen_id }}">
        <h3 class="ai-collection-listing__empty-state-title-{{ ai_gen_id }}">No products found</h3>
        <p class="ai-collection-listing__empty-state-text-{{ ai_gen_id }}">This collection is currently empty.</p>
      </div>
    {% endif %}
  {% else %}
    <div class="ai-collection-listing__empty-state-{{ ai_gen_id }}">
      <h3 class="ai-collection-listing__empty-state-title-{{ ai_gen_id }}">Select a collection</h3>
      <p class="ai-collection-listing__empty-state-text-{{ ai_gen_id }}">Choose a collection to display its products.</p>
    </div>
  {% endif %}
</collection-listing-{{ ai_gen_id }}>

<script>
  (function() {
    class CollectionListing{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.style.display = 'block';
      }
    }

    customElements.define('collection-listing-{{ ai_gen_id }}', CollectionListing{{ ai_gen_id }});
  })();
</script>

{% schema %}
