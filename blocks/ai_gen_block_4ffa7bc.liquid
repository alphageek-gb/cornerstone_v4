{% doc %}
  @prompt
    A magazine-style editorial layout
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-magazine-layout-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    max-width: 1400px;
    margin: 0 auto;
    padding: {{ block.settings.section_padding }}px 20px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-magazine-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: {{ block.settings.grid_gap }}px;
    width: 100%;
  }

  .ai-magazine-article-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    border-radius: {{ block.settings.border_radius }}px;
    background-color: {{ block.settings.card_background }};
    transition: transform 0.3s ease;
  }

  .ai-magazine-article-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
  }

  .ai-magazine-article-{{ ai_gen_id }}--featured {
    grid-column: span 8;
    grid-row: span 2;
  }

  .ai-magazine-article-{{ ai_gen_id }}--secondary {
    grid-column: span 4;
  }

  .ai-magazine-article-{{ ai_gen_id }}--tertiary {
    grid-column: span 4;
  }

  .ai-magazine-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
  }

  .ai-magazine-article-{{ ai_gen_id }}--featured .ai-magazine-image-wrapper-{{ ai_gen_id }} {
    padding-bottom: 65%;
  }

  .ai-magazine-article-{{ ai_gen_id }}--secondary .ai-magazine-image-wrapper-{{ ai_gen_id }},
  .ai-magazine-article-{{ ai_gen_id }}--tertiary .ai-magazine-image-wrapper-{{ ai_gen_id }} {
    padding-bottom: 75%;
  }

  .ai-magazine-image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-magazine-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-magazine-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-magazine-overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(to bottom, transparent 0%, rgba(0, 0, 0, {{ block.settings.overlay_opacity }}) 100%);
    pointer-events: none;
  }

  .ai-magazine-content-{{ ai_gen_id }} {
    position: relative;
    padding: {{ block.settings.content_padding }}px;
    color: {{ block.settings.text_color }};
  }

  .ai-magazine-article-{{ ai_gen_id }}--featured .ai-magazine-content-{{ ai_gen_id }} {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    color: {{ block.settings.overlay_text_color }};
  }

  .ai-magazine-category-{{ ai_gen_id }} {
    display: inline-block;
    font-size: {{ block.settings.category_size }}px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 8px;
    color: {{ block.settings.accent_color }};
  }

  .ai-magazine-article-{{ ai_gen_id }}--featured .ai-magazine-category-{{ ai_gen_id }} {
    color: {{ block.settings.accent_color }};
  }

  .ai-magazine-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    font-weight: 600;
    line-height: 1.2;
    margin: 0 0 12px;
  }

  .ai-magazine-article-{{ ai_gen_id }}--featured .ai-magazine-title-{{ ai_gen_id }} {
    font-size: calc({{ block.settings.title_size }}px * 1.5);
  }

  .ai-magazine-article-{{ ai_gen_id }}--secondary .ai-magazine-title-{{ ai_gen_id }},
  .ai-magazine-article-{{ ai_gen_id }}--tertiary .ai-magazine-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
  }

  .ai-magazine-excerpt-{{ ai_gen_id }} {
    font-size: {{ block.settings.excerpt_size }}px;
    line-height: 1.6;
    margin: 0 0 16px;
    opacity: 0.9;
  }

  .ai-magazine-article-{{ ai_gen_id }}--secondary .ai-magazine-excerpt-{{ ai_gen_id }},
  .ai-magazine-article-{{ ai_gen_id }}--tertiary .ai-magazine-excerpt-{{ ai_gen_id }} {
    display: none;
  }

  .ai-magazine-meta-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: {{ block.settings.meta_size }}px;
    opacity: 0.8;
  }

  .ai-magazine-link-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }

  @media screen and (max-width: 989px) {
    .ai-magazine-article-{{ ai_gen_id }}--featured {
      grid-column: span 12;
      grid-row: span 1;
    }

    .ai-magazine-article-{{ ai_gen_id }}--secondary {
      grid-column: span 6;
    }

    .ai-magazine-article-{{ ai_gen_id }}--tertiary {
      grid-column: span 6;
    }

    .ai-magazine-article-{{ ai_gen_id }}--featured .ai-magazine-title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.title_size }}px * 1.2);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-magazine-grid-{{ ai_gen_id }} {
      gap: {{ block.settings.grid_gap | times: 0.7 }}px;
    }

    .ai-magazine-article-{{ ai_gen_id }}--featured,
    .ai-magazine-article-{{ ai_gen_id }}--secondary,
    .ai-magazine-article-{{ ai_gen_id }}--tertiary {
      grid-column: span 12;
    }

    .ai-magazine-content-{{ ai_gen_id }} {
      padding: {{ block.settings.content_padding | times: 0.7 }}px;
    }

    .ai-magazine-article-{{ ai_gen_id }}--featured .ai-magazine-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size }}px;
    }

    .ai-magazine-article-{{ ai_gen_id }}--secondary .ai-magazine-excerpt-{{ ai_gen_id }},
    .ai-magazine-article-{{ ai_gen_id }}--tertiary .ai-magazine-excerpt-{{ ai_gen_id }} {
      display: block;
    }
  }
{% endstyle %}

