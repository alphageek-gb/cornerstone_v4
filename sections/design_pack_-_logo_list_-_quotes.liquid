{%- comment -%} JSON Settings {%- endcomment -%}
<script type="application/json" data-dsgn-pck="{{ section_id }}">
  {
    "id": {{ section_id | json }},
    "show_arrows": {{ section.settings.show_arrows | json }},
    "autoplay": {{ section.settings.autoplay | times: 1000 | json }},
    "slider_animation": {%- if section.settings.slider_animation == 'fade' -%}true{%- else -%}false{%- endif -%},
    "enable_parallax": {{ section.settings.enable_parallax | json }}
  }
</script>
{%- comment -%} External scripts {%- endcomment -%}
<script data-dsgn-pck-external-js="{{ section_id }}" src="https://cdn.shopify.com/s/files/1/0577/7673/4361/files/flickity-2.3.0.pkgd.min.js?v=1671485005" defer></script>
{%- if section.settings.slider_animation == 'fade' -%}
  <script data-dsgn-pck-external-js="{{ section_id }}" src="https://cdn.shopify.com/s/files/1/0577/7673/4361/files/flickity-fade-1.0.0.min.js?v=1659560790" defer></script>
{%- endif -%}
{%- if section.settings.enable_parallax -%}
  <script data-dsgn-pck-external-js="{{ section_id }}" src="https://cdn.shopify.com/s/files/1/0577/7673/4361/files/jarallax.min.js?v=1638490357" defer></script>
{%- endif -%}
{%- comment -%} JavaScript {%- endcomment -%}
<script data-dsgn-pck-js="{{ section_id }}" type="module" defer>
(function(){

  const designPack = {
    settings: {},
    goToSlide: function(index){
      designPack.flkty.select( index, true, true )
    },
    enableParallax: function(section){
      const image = section.querySelector(`.dsgn-pck__parallax-img`);
      jarallax(section, {
        speed: 0.2,
        imgElement: image
      });
    },
    load: function(section){

      const elem = section.querySelector(`[data-quote-slider]`);
      designPack.flkty = new Flickity( elem, {
        cellAlign: 'left',
        autoPlay: this.settings.autoplay,
        contain: true,
        wrapAround: JSON.parse(getComputedStyle(section).getPropertyValue('--wrap-around')),
        adaptiveHeight: JSON.parse(getComputedStyle(section).getPropertyValue('--adaptive-height')),
        imagesLoaded: true,
        fade: this.settings.slider_animation,
        prevNextButtons: this.settings.show_arrows,
        pageDots: JSON.parse(getComputedStyle(section).getPropertyValue('--page-dots')),
        draggable: JSON.parse(getComputedStyle(section).getPropertyValue('--draggable')),
        freeScrollFriction: getComputedStyle(section).getPropertyValue('--free-scroll-friction'),
        selectedAttraction: getComputedStyle(section).getPropertyValue('--selected-attraction'),
        friction: getComputedStyle(section).getPropertyValue('--friction'),
        dragThreshold: getComputedStyle(section).getPropertyValue('--drag-threshold'),
        on: {
          change: function( index ) {
            const color = this.selectedElement.dataset.slideshowColor;
            section.style.setProperty('--slideshow-color', color);
          }
        }
      });

      var sliderNav = section.querySelector('[data-quote-nav]');
      var galleryNavItems = sliderNav.querySelectorAll('.dsgn-pck__quote-nav-item');

      designPack.flkty.on('select', function() {
        var selected = sliderNav.querySelector('.dsgn-pck__quote-nav-item--selected');
        if (selected) {
          selected.classList.remove('dsgn-pck__quote-nav-item--selected');
        }
        galleryNavItems[designPack.flkty.selectedIndex].classList.add('dsgn-pck__quote-nav-item--selected');
      });

      galleryNavItems.forEach(function(item, index) {
        item.addEventListener('click', function() {
          designPack.flkty.select(index);
        })
      })


      if (this.settings.enable_parallax == true){
        this.enableParallax(section);
      }

    },
    unload: function(section){
      designPack.flkty.destroy();
    }
  }

  window.addEventListener('shopify:section:unload', function (e) {
    const settings = document.querySelector(`[data-dsgn-pck="${e.detail.sectionId}"]`);
    const sectionId = e.detail.sectionId;
    const section = document.querySelector(`#DP--${e.detail.sectionId}`);
    if (sectionId == designPack.settings.id){
      designPack.unload(section);
    }
  });

  window.addEventListener('shopify:block:select', function (e) {
    const section = document.querySelector(`#DP--${e.detail.sectionId}`);
    designPack.goToSlide(e.target.dataset.slideshowIndex);
  });

  designPack.settings = JSON.parse(document.querySelector('[data-dsgn-pck="{{ section_id }}"]').innerHTML);
  const sectionId = {{ section_id | json }};
  const section = document.querySelector(`#DP--${sectionId}`);

  if (sectionId == designPack.settings.id){
    designPack.load(section);
  }
})()
</script>
