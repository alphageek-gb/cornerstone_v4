            "expand_by_default": false,
            "icon": "none",
            "title": "Can I get a refund if I'm not satisfied with my furniture purchase?",
            "text": "<p>Absolutely! We offer a hassle-free refund policy within [specified timeframe] from the date of delivery. Check our Refund Policy page for more details.</p>"
          }
