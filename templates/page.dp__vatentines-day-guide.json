ges\/always-forever_6f427fbd-89ef-4254-9958-c505d9077697.png"}},"feature_PBkmei":{"type":"feature","settings":{"title":"A Hug You Can Hold","main_heading":"A Hug You Can Hold, Always","text":"<p>Wrap your love in warmth with a handmade pen crafted from a <strong>teddy bear wood inlay kit<\/strong>, designed to capture the comfort, sweetness, and nostalgia of a timeless symbol of love. Carefully turned and thoughtfully finished, this pen transforms a simple gesture into a lasting keepsake—one that reminds them of your affection every time it’s picked up. More than a Valentine’s gift, it’s a gentle hug they can carry with them, always. 🧸✍️<\/p>","image":"shopify:\/\/shop_images\/teddy-bear-valentine-promo.png"}}},"block_order":["feature_VEFpz8","feature_VYVDFk","feature_PBkmei"],"settings":{"highlight_position":"bottom","image_position":"right","image_crop":"none","text_alignment":"left","text_size":100,"text_color":"#d24957","text_hover_color":"#ffd5d5","background_solid":"","background_color":"#FFF3F3","base_width":80,"max_width":"","inner_padding":40,"outer_margin":0,"custom_css":"","mobile_custom_css":"","anchor_id":"","custom_classes":"","override_theme_font":true,"heading_font":"bevan_n4","main_font":"system_ui_n4","enable_metafield_detect":false}},"design_pack_fixed_back_to_top_QH4FfN":{"type":"design_pack_-_fixed_back_to_top","settings":{"scroll_appear":20,"icon":"line_angle_up","size":100,"text":"Back to top","alignment":"right","margin":20,"opacity":85,"border_radius":13,"text_color":"#ffffff","background_solid":"","background_color":"#D24957","show_shadow":false,"hide_on_mobile":true,"custom_css":"","mobile_custom_css":""}},"design_pack_hide_header_or_footer_JDPULi":{"type":"design_pack_-_hide_header_or_footer","settings":{"hide_header":false,"hide_footer":false,"additional_classes":""}}},"order":["design_pack_banner_image_gallery_EAT6ga","design_pack_cutout_bottom_p4kxxQ","design_pack_link_menu_icons_aUBxqC","design_pack_heading_DkUBTU","design_pack_featur